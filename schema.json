{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tca.dev/schema/v1.0/pragmatic",
  "title": "Terminal Color Architecture (TCA) v1.0 Pragmatic Mode",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "palette", "ansi"],

  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "author": { "type": "string" },
        "version": { "type": "string" }
      }
    },

    "palette": {
      "type": "object",
      "minProperties": 1,
      "required": ["neutral"],
      "additionalProperties": { "$ref": "#/$defs/hueRampOptional" },
      "properties": {
        "neutral": { "$ref": "#/$defs/hueRamp" }
      }
    },

    "semantic": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/paletteReference"
      }
    },

    "ui": {
      "type": "object",
      "patternProperties": {
        "^[a-z]+(\\.[a-z]+)?$": {
          "$ref": "#/$defs/tokenReference"
        }
      },
      "additionalProperties": false
    },

    "ansi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "black", "red", "green", "yellow", "blue", "magenta", "cyan", "white",
        "brightBlack", "brightRed", "brightGreen", "brightYellow",
        "brightBlue", "brightMagenta", "brightCyan", "brightWhite"
      ],
      "properties": {
        "black": { "$ref": "#/$defs/paletteReference" },
        "red": { "$ref": "#/$defs/paletteReference" },
        "green": { "$ref": "#/$defs/paletteReference" },
        "yellow": { "$ref": "#/$defs/paletteReference" },
        "blue": { "$ref": "#/$defs/paletteReference" },
        "magenta": { "$ref": "#/$defs/paletteReference" },
        "cyan": { "$ref": "#/$defs/paletteReference" },
        "white": { "$ref": "#/$defs/paletteReference" },
        "brightBlack": { "$ref": "#/$defs/paletteReference" },
        "brightRed": { "$ref": "#/$defs/paletteReference" },
        "brightGreen": { "$ref": "#/$defs/paletteReference" },
        "brightYellow": { "$ref": "#/$defs/paletteReference" },
        "brightBlue": { "$ref": "#/$defs/paletteReference" },
        "brightMagenta": { "$ref": "#/$defs/paletteReference" },
        "brightCyan": { "$ref": "#/$defs/paletteReference" },
        "brightWhite": { "$ref": "#/$defs/paletteReference" }
      }
    },

    "base16": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^base0[0-9A-F]$": {
          "$ref": "#/$defs/paletteReference"
        }
      }
    }
  },

  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#([0-9a-fA-F]{6})$"
    },

    "hueRamp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["1", "2", "3", "4", "5"],
      "properties": {
        "1": { "$ref": "#/$defs/hexColor" },
        "2": { "$ref": "#/$defs/hexColor" },
        "3": { "$ref": "#/$defs/hexColor" },
        "4": { "$ref": "#/$defs/hexColor" },
        "5": { "$ref": "#/$defs/hexColor" }
      }
    },

    "hueRampOptional": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/hexColor" }
    },

    "paletteReference": {
      "type": "string",
      "pattern": "^palette\\.[a-z]+\\.[1-5]$"
    },

    "semanticReference": {
      "type": "string",
      "pattern": "^semantic\\.[a-z]+$"
    },

    "tokenReference": {
      "type": "string",
      "anyOf": [
        { "$ref": "#/$defs/paletteReference" },
        { "$ref": "#/$defs/semanticReference" }
      ]
    }
  }
}


{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terminalcolors.dev/schema/v1.0/pragmatic",
  "title": "Terminal Color Architecture (TCA) v1.0",
  "description": "Schema for TCA theme files. Themes are written in TOML and validated by converting to JSON.",
  "type": "object",
  "additionalProperties": false,
  "required": ["theme", "ansi", "semantic", "ui"],

  "properties": {
    "theme": {
      "description": "Theme metadata ([theme] section).",
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "author": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "dark": { "type": "boolean" }
      }
    },

    "ansi": {
      "description": "ANSI 16-color definitions ([ansi] section). All values must be #RRGGBB hex strings — no references allowed.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "black",
        "red",
        "green",
        "yellow",
        "blue",
        "magenta",
        "cyan",
        "white",
        "bright_black",
        "bright_red",
        "bright_green",
        "bright_yellow",
        "bright_blue",
        "bright_magenta",
        "bright_cyan",
        "bright_white"
      ],
      "properties": {
        "black": { "$ref": "#/$defs/hexColor" },
        "red": { "$ref": "#/$defs/hexColor" },
        "green": { "$ref": "#/$defs/hexColor" },
        "yellow": { "$ref": "#/$defs/hexColor" },
        "blue": { "$ref": "#/$defs/hexColor" },
        "magenta": { "$ref": "#/$defs/hexColor" },
        "cyan": { "$ref": "#/$defs/hexColor" },
        "white": { "$ref": "#/$defs/hexColor" },
        "bright_black": { "$ref": "#/$defs/hexColor" },
        "bright_red": { "$ref": "#/$defs/hexColor" },
        "bright_green": { "$ref": "#/$defs/hexColor" },
        "bright_yellow": { "$ref": "#/$defs/hexColor" },
        "bright_blue": { "$ref": "#/$defs/hexColor" },
        "bright_magenta": { "$ref": "#/$defs/hexColor" },
        "bright_cyan": { "$ref": "#/$defs/hexColor" },
        "bright_white": { "$ref": "#/$defs/hexColor" }
      }
    },

    "palette": {
      "description": "Named color ramps ([palette] section). Each ramp is a 0-indexed array ordered darkest to lightest. Values are #RRGGBB hex or ansi.* references.",
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/paletteRampValue" },
        "minItems": 1
      }
    },

    "base16": {
      "description": "Base16/24 compatibility mappings ([base16] section). Keys are base00–base0F (Base16) or base00–base17 (Base24). Values are hex, ansi.*, or palette.* references.",
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^base0[0-9A-F]$": { "$ref": "#/$defs/base16Value" },
        "^base1[0-7]$": { "$ref": "#/$defs/base16Value" }
      }
    },

    "semantic": {
      "description": "Semantic color roles ([semantic] section). Values are hex, ansi.*, palette.*, or base16.* references.",
      "type": "object",
      "additionalProperties": false,
      "required": ["error", "warning", "info", "success", "highlight", "link"],
      "properties": {
        "error": { "$ref": "#/$defs/colorRef" },
        "warning": { "$ref": "#/$defs/colorRef" },
        "info": { "$ref": "#/$defs/colorRef" },
        "success": { "$ref": "#/$defs/colorRef" },
        "highlight": { "$ref": "#/$defs/colorRef" },
        "link": { "$ref": "#/$defs/colorRef" }
      }
    },

    "ui": {
      "description": "UI element colors ([ui] section with nested sub-tables). Values are hex, ansi.*, palette.*, or base16.* references.",
      "type": "object",
      "additionalProperties": false,
      "required": ["bg", "fg", "border", "cursor", "selection"],
      "properties": {
        "bg": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "secondary"],
          "properties": {
            "primary": { "$ref": "#/$defs/colorRef" },
            "secondary": { "$ref": "#/$defs/colorRef" }
          }
        },
        "fg": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "secondary", "muted"],
          "properties": {
            "primary": { "$ref": "#/$defs/colorRef" },
            "secondary": { "$ref": "#/$defs/colorRef" },
            "muted": { "$ref": "#/$defs/colorRef" }
          }
        },
        "border": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "muted"],
          "properties": {
            "primary": { "$ref": "#/$defs/colorRef" },
            "muted": { "$ref": "#/$defs/colorRef" }
          }
        },
        "cursor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "muted"],
          "properties": {
            "primary": { "$ref": "#/$defs/colorRef" },
            "muted": { "$ref": "#/$defs/colorRef" }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["bg", "fg"],
          "properties": {
            "bg": { "$ref": "#/$defs/colorRef" },
            "fg": { "$ref": "#/$defs/colorRef" }
          }
        }
      }
    }
  },

  "$defs": {
    "hexColor": {
      "description": "A 6-digit hex color: #RRGGBB",
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },

    "ansiRef": {
      "description": "Reference to an ANSI color: ansi.<name>",
      "type": "string",
      "pattern": "^ansi\\.(black|red|green|yellow|blue|magenta|cyan|white|bright_black|bright_red|bright_green|bright_yellow|bright_blue|bright_magenta|bright_cyan|bright_white)$"
    },

    "paletteRef": {
      "description": "Reference to a palette ramp entry: palette.<ramp>.<index>",
      "type": "string",
      "pattern": "^palette\\.[a-z][a-z0-9_]*\\.[0-9]+$"
    },

    "base16Ref": {
      "description": "Reference to a base16 entry: base16.base0X",
      "type": "string",
      "pattern": "^base16\\.base0[0-9A-F]$"
    },

    "paletteRampValue": {
      "description": "A value within a palette ramp: hex or ansi.* only (palette values may not reference other palette or base16 entries).",
      "type": "string",
      "anyOf": [{ "$ref": "#/$defs/hexColor" }, { "$ref": "#/$defs/ansiRef" }]
    },

    "base16Value": {
      "description": "A value in the base16 section: hex, ansi.*, or palette.* (base16 entries may not reference other base16 entries).",
      "type": "string",
      "anyOf": [
        { "$ref": "#/$defs/hexColor" },
        { "$ref": "#/$defs/ansiRef" },
        { "$ref": "#/$defs/paletteRef" }
      ]
    },

    "colorRef": {
      "description": "A fully general color reference: hex, ansi.*, palette.*.N, or base16.*",
      "type": "string",
      "anyOf": [
        { "$ref": "#/$defs/hexColor" },
        { "$ref": "#/$defs/ansiRef" },
        { "$ref": "#/$defs/paletteRef" },
        { "$ref": "#/$defs/base16Ref" }
      ]
    }
  }
}
